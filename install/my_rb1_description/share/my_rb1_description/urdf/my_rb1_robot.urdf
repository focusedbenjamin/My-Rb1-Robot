<?xml version="1.0" ?>
<robot name="rb1_robot">

    <!-- Define materials for visualization -->
    <material name="blue">
        <color rgba="0 0 1 1"/>
    </material>

    <material name="gray">
        <color rgba="0.40 0.40 0.40 1"/>
    </material>

    <material name="red">
        <color rgba="1 0 0 1"/>
    </material>

    <!-- Base footprint link -->
    <link name="base_footprint">
    </link>

    <!-- Joint connecting base_link and base_footprint -->
    <joint name="base_link_plate_joint" type="fixed">
        <origin xyz="0 0 0.15" rpy="0 0 0"/>
        <parent link="base_footprint"/>
        <child link="base_link"/>
    </joint>

    <!-- Base link -->
    <link name="base_link">
        <visual>
            <geometry>
                <cylinder radius="0.25" length="0.3"/>
            </geometry>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.25" length="0.3"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="20.0"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia ixx="0.4625" ixy="0.0" ixz="0.0"
                     iyy="0.4625" iyz="0.0"
                     izz="0.625"/>
        </inertial>
    </link>

    <!-- Left wheel link -->
    <link name="left_wheel">
        <visual>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry>
            <cylinder radius ="0.025" length="0.02"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry>
            <cylinder radius="0.025" length="0.02"/>
            </geometry>
        </collision>        
        <inertial>
            <mass value="1.0"/>
            <origin xyz="0 0 0"/>
            <inertia ixx="0.0002" ixy="0" ixz="0"
                     iyy="0.0001" iyz="0"
                     izz="0.0002"/>
        </inertial>
    </link>

    <!-- Joint connecting base_link and left_wheel -->
    <joint name="base_link_left_wheel_joint" type="revolute">
        <origin xyz="0 0.2 -0.15" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <parent link="base_link"/>
        <child link="left_wheel"/>
    </joint>

    <!-- Right wheel link -->
    <link name="right_wheel">
        <visual>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry>
                <cylinder radius="0.025" length="0.02"/>
            </geometry>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry>
                <cylinder radius="0.025" length="0.02"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="1.0"/>
            <origin xyz="0 0 0"/>
            <inertia ixx="0.0002" ixy="0" ixz="0"
                     iyy="0.0001" iyz="0"
                     izz="0.0002"/>
        </inertial>
    </link>

    <!-- Joint connecting base_link and right_wheel -->
    <joint name="base_link_right_wheel_joint" type="revolute">
        <origin xyz="0.0 -0.2 -0.15" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <parent link="base_link"/>
        <child link="right_wheel"/>
    </joint>

    <!-- Front caster -->
    <link name="front_caster">
        <visual>
            <geometry>
                <sphere radius="0.025" />
            </geometry>
        </visual>
        <collision>
            <geometry>
                <sphere radius="0.025"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="0.5"/>
            <origin xyz="0 0 0"/>
            <inertia ixx="0.0001" ixy="0" ixz="0"
                     iyy="0.0001" iyz="0"
                     izz="0.0001"/>
        </inertial>
    </link>

    <!-- Joint connecting base_link and front_caster -->
    <!-- TO DO: Set correct joint type -->
    <joint name="base_link_front_caster_joint" type="fixed">
        <origin xyz="-0.1 0.0 -0.15" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="front_caster"/>
    </joint>

    <!-- Back caster -->
    <link name="back_caster">
        <visual>
            <geometry>
                <sphere radius="0.025"/>
            </geometry>
        </visual>

        <collision>
            <geometry>
                <sphere radius="0.025"/>
            </geometry>
        </collision>

        <inertial>
                <mass value="0.5"/>
                <origin xyz="0 0 0"/>
                <inertia ixx="0.0001" ixy="0" ixz="0"
                         iyy="0.0001" iyz="0"
                         izz="0.0001"/>
        </inertial>
    </link>

    <!-- Joint connecting base_link and back_caster -->
    <!-- TO DO: Set correct joint type -->
    <joint name="base_link_back_caster_joint" type="fixed">
        <origin xyz="0.1 0.0 -0.15" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="back_caster"/>
    </joint>

    <!-- Link representing the front laser scanner -->
    <!--For this robot, the laser is not visible, so we won't define a body for it. -->
    <link name="front_laser">
    </link>

    <!-- Joint connecting base_link and front_laser -->
    <!-- TO DO: Set correct joint type -->
    <joint name="base_link_front_laser_joint" type="fixed">
        <!-- TO DO: Define axis (if needed) -->
        <origin xyz="0.25 0.0 0.075" rpy="3.1416 0 0"/>
        <parent link="base_link"/>
        <child link="front_laser"/>
    </joint>

    <!-- Specify Gazebo color for the base_link -->
    <gazebo reference="base_link">
        <visual>
            <material>
                <ambient>0 0 0 1</ambient>
                <diffuse>0 0 0 1</diffuse>
                <specular>0.1 0.1 0.1 1</specular>
            </material>
        </visual>
    </gazebo>

    <!-- Gazebo friction and material properties for left_wheel -->
    <gazebo reference="left_wheel">
        <collision>
            <surface>
                <friction>
                    <ode>
                        <mu>1.0</mu>
                        <mu2>1.0</mu2>
                    </ode>
                </friction>
            </surface>
        </collision>
    </gazebo>

    <!-- Gazebo friction and material properties for right_wheel -->
    <gazebo reference="right_wheel">
        <collision>
            <surface>
                <friction>
                    <ode>
                        <mu>1.0</mu>
                        <mu2>1.0</mu2>
                    </ode>
                </friction>
            </surface>
        </collision>
    </gazebo>

    <!-- Gazebo friction and material properties for front_caster -->
    <gazebo reference="front_caster">
        <collision>
            <surface>
                <friction>
                    <ode>
                        <mu>1.0</mu>
                        <mu2>1.0</mu2>
                    </ode>
                </friction>
            </surface>
        </collision>
    </gazebo>

    <!-- Gazebo friction and material properties for back_caster -->
    <gazebo reference="back_caster">
        <collision>
            <surface>
                <friction>
                    <ode>
                        <mu>1.0</mu>
                        <mu2>1.0</mu2>
                    </ode>
                </friction>
            </surface>
        </collision>
    </gazebo>

    <gazebo>
      <plugin filename="gz-sim-diff-drive-system"
        name="gz::sim::systems::DiffDrive">

        <left_joint>base_link_left_wheel_joint</left_joint>
        <right_joint>base_link_right_wheel_joint</right_joint>

        <wheel_separation>0.4</wheel_separation>
        <wheel_radius>0.025</wheel_radius>

        <topic>/cmd_vel</topic>

        <odom_topic>/odom</odom_topic>

        <frame_id>base_link</frame_id>
        <odom_frame_id>odom</odom_frame_id>

        <publish_odom>true</publish_odom>
        <publish_tf>true</publish_tf>

    </plugin>
    </gazebo>

    <gazebo reference="front_laser">
        <sensor name="front_laser_sensor" type="gpu_lidar">

          <always_on>true</always_on>
          <update_rate>10</update_rate>
          <visualize>true</visualize>

          <topic>/scan</topic>

          <lidar>
            <scan>
              <horizontal>
                <samples>720</samples>
                <min_angle>-1.57</min_angle>
                <max_angle>1.57</max_angle>
              </horizontal>
            </scan>

            <range>
              <min>0.12</min>
              <max>10.0</max>
            </range>
          </lidar>

         </sensor>
    </gazebo>



</robot>